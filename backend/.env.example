# URL PocketBase, например http://127.0.0.1:8090
POCKETBASE_URL=http://127.0.0.1:8090

# Администратор PocketBase (или пользователь с правами записи)
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=strongpassword

# Простой токен для модератора, вставьте произвольную строку
APP_MODERATOR_TOKEN=super-secret-moderator-token

# Порт сервера логики
PORT=4000
